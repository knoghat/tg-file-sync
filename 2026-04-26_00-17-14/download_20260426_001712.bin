    <button id="load-more-btn" class="ld-more mt-4 px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700"
            data-album-id="404098" 
            data-file-id="38149608" 
            data-offset="5">
        Load More <span id="loading" class="hidden ml-2">Loading...</span>
    </button>
    
</div>
<script>
document.getElementById('load-more-btn')?.addEventListener('click', function() {
    const button = this;
    const albumId = button.getAttribute('data-album-id');
    const fileId = button.getAttribute('data-file-id');
    let offset = parseInt(button.getAttribute('data-offset'));

    button.disabled = true;
    document.getElementById('loading').classList.remove('hidden');

    fetch(`/more-related-files?album_id=${albumId}&file_id=${fileId}&offset=${offset}`)
        .then(response => {
            if (response.headers.get('X-Has-More') === 'false') {
                button.style.display = 'none';
            }
            return response.text();
        })
        .then(html => {
            document.getElementById('related-files-grid').insertAdjacentHTML('beforeend', html);
            offset += 5;
            button.setAttribute('data-offset', offset);
            button.disabled = false;
            document.getElementById('loading').classList.add('hidden');
        })
        .catch(error => {
            console.error('Error loading more files:', error);
            button.disabled = false;
            document.getElementById('loading').classList.add('hidden');
        });
});
</script>


<style>
    .live-indicator-container {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: Arial, sans-serif;
    }
    
    .live-dot {
        position: relative;
        width: 10px;
        height: 10px;
    }
    
    .dot {
        width: 10px;
        height: 10px;
        background-color: #4CAF50;  
        border-radius: 50%;
        position: absolute;
    }
    
    .pulse {
        width: 10px;
        height: 10px;
        background-color: #4CAF50;  
        border-radius: 50%;
        position: absolute;
        animation: pulse 1.5s ease-in-out infinite;
    }
    
    @keyframes pulse {
        0% {
            transform: scale(1);
            opacity: 0.7;
        }
        70% {
            transform: scale(2);
            opacity: 0;
        }
        100% {
            transform: scale(1);
            opacity: 0;
        }
    }
    
    #liveCount {
        font-size: 14px;
    }
</style>
<script>
document.addEventListener("DOMContentLoaded", function () {
    const slug = "lXKz2qxgOaREl";
    const viewCountEl = document.getElementById("liveCount");

    const wsProtocol = window.location.protocol === "https:" ? "wss://" : "ws://";
    const ws = new WebSocket(wsProtocol + window.location.host + "/ws/viewers?file=" + slug);

    ws.onmessage = function (event) {
        const data = JSON.parse(event.data);
        if (data.viewers !== undefined) {
            viewCountEl.textContent = data.viewers === 1 
                ? "1 Live user" 
                : data.viewers + " Live users";
        }
    };
});

    </script>

