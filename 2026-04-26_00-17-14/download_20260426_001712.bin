<script>
document.addEventListener('DOMContentLoaded', () => {
    const fileTracker = document.getElementById('fileTracker');
    if (!fileTracker) {
        console.error('Error: fileTracker element not found');
        return;
    }

    const fileId = fileTracker.getAttribute('data-file-id');
    if (!fileId) {
        console.error('Error: data-file-id is missing or invalid');
        return;
    }

    
    fetch(`https://s.bunkr.ru/api/file/stats/${fileId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
    })
        .then(response => response.json())
        .then(data => console.log('Success (POST):', data))
        .catch(error => console.error('Error (POST):', error));

    
    fetch(`https://s.bunkr.ru/api/file/stats/${fileId}`)
        .then(response => response.json())
        .then(data => {
            const countDisplay = document.getElementById('downloadCount');
            if (data.downloadCount !== undefined) {
                countDisplay.textContent = `${data.downloadCount} views`;
                countDisplay.style.display = 'inline';
            } else {
                console.error('Error: downloadCount is undefined in response', data);
            }
        })
        .catch(error => console.error('Error fetching download count:', error));
});
</script>

    



